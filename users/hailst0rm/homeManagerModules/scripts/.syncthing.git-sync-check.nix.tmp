{
  pkgs,
  config,
  lib,
  ...
}: let
  hasDesktop = config.importConfig.hyprland.enable;
  nixosDir = config.nixosDir;
  stateDir = "${config.xdg.stateHome}/nix-sync-check";

  # Shared logic for checking remote and building the update message
  checkScript = pkgs.writeShellScriptBin "nix-check-remote" ''
    #!/usr/bin/env sh

    cd ${nixosDir}

    # Test GitHub connectivity via SSH
    MAX_RETRIES=12  # Check for up to 1 hour (12 * 5 minutes)
    RETRY_COUNT=0
    CONNECTION_OK=false

    while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
      if timeout 5 git ls-remote git@github.com:hailst0rm1/nixos.git HEAD &>/dev/null; then
        CONNECTION_OK=true
        break
      else
        if [ $RETRY_COUNT -eq 0 ]; then
          ${
      if hasDesktop
      then ''
        if command -v zenity &> /dev/null; then
          zenity --warning \
            --title="GitHub Connection Failed" \
            --text="Cannot reach GitHub via SSH.\n\nWill keep checking in the background every 5 minutes.\nYou'll be notified when updates are available." \
            --width=400 \
            --timeout=10 &
        fi
        notify-send "NixOS Config Sync" "Cannot reach GitHub. Will keep checking..." --icon=dialog-warning &
      ''
      else ''
        echo "Cannot reach GitHub via SSH. Will keep checking in the background every 5 minutes."
      ''
    }
        fi
        RETRY_COUNT=$((RETRY_COUNT + 1))
        sleep 300
      fi
    done

    if [ "$CONNECTION_OK" = false ]; then
      exit 0
    fi

    # Fetch remote changes without merging
    git fetch origin master --quiet

    # Check if local is behind remote
    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/master)

    if [ "$LOCAL" = "$REMOTE" ]; then
      # Up to date — clear any stale notification file
      rm -f "${stateDir}/update-available" 2>/dev/null
      exit 0
    fi

    # Count commits behind
    BEHIND=$(git rev-list HEAD..origin/master --count)

    # Get commit messages and parse them
    COMMITS=$(while IFS= read -r line; do
      if echo "$line" | grep -q ":"; then
        MESSAGE=$(echo "$line" | cut -d':' -f2-)
        MESSAGE=$(echo "$MESSAGE" | sed 's/ ([^)]*)$//')
        MESSAGE=$(echo "$MESSAGE" | sed 's/^ *//;s/ *$//')
        echo "• $MESSAGE"
      else
        echo "• $line"
      fi
    done <<< "$(git log HEAD..origin/master --pretty=format:"%s")")

    # Get list of changed files (limit to 10)
    CHANGED_FILES=$(git diff --name-only HEAD origin/master | head -10 | sed 's/^/• /')
    FILE_COUNT=$(git diff --name-only HEAD origin/master | wc -l)

    if [ "$FILE_COUNT" -gt 10 ]; then
      CHANGED_FILES="$CHANGED_FILES
    • ... and $((FILE_COUNT - 10)) more files"
    fi

    ${
      if hasDesktop
      then ''
        # Desktop: GUI prompt
        if command -v zenity &> /dev/null; then
          zenity --question \
            --title="NixOS Config Updates Available" \
            --text="Your NixOS configuration is $BEHIND commit(s) behind remote.\n\n<b>Commits:</b>\n$COMMITS\n\n<b>Changed files:</b>\n$CHANGED_FILES\n\nWould you like to pull the changes now?" \
            --width=500 \
            --height=400

          if [ $? -eq 0 ]; then
            git pull origin master
            notify-send "NixOS Config" "Successfully pulled $BEHIND commit(s) from remote" --icon=dialog-information
          else
            notify-send "NixOS Config" "Skipped pulling remote changes" --icon=dialog-warning
          fi
        fi
      ''
      else ''
            # Server: Write notification to state file for terminal display
            mkdir -p "${stateDir}"
            cat > "${stateDir}/update-available" << ENDMSG
        BEHIND=$BEHIND
        COMMITS=$(echo "$COMMITS" | sed 's/"/\\"/g')
        CHANGED_FILES=$(echo "$CHANGED_FILES" | sed 's/"/\\"/g')
        ENDMSG
      ''
    }
  '';

  # Build freshness check — is the running system built from the latest config?
  buildCheckScript = pkgs.writeShellScriptBin "nix-check-build" ''
    #!/usr/bin/env sh

    cd ${nixosDir} 2>/dev/null || exit 0

    JQ="${pkgs.jq}/bin/jq"

    BUILT_REV=$(nixos-version --json 2>/dev/null | $JQ -r '.configurationRevision // empty' 2>/dev/null)
    CURRENT_REV=$(git rev-parse HEAD 2>/dev/null)

    if [ -z "$BUILT_REV" ] || [ -z "$CURRENT_REV" ]; then
      # No configurationRevision yet (first build needed) — skip
      exit 0
    fi

    # Strip -dirty suffix for comparison
    BUILT_REV_CLEAN="''${BUILT_REV%-dirty}"
    PARENT_REV=$(git rev-parse HEAD~1 2>/dev/null)

    # Check if build is current (exact match or parent = post-build commit)
    if [ "$BUILT_REV_CLEAN" = "$CURRENT_REV" ] || [ "$BUILT_REV_CLEAN" = "$PARENT_REV" ]; then
      rm -f "${stateDir}/build-stale" 2>/dev/null
      exit 0
    fi

    # Build is stale — count how far behind
    COMMITS_BEHIND=$(git rev-list "$BUILT_REV_CLEAN"..HEAD --count 2>/dev/null || echo "?")
    if [ "$COMMITS_BEHIND" -gt 1 ] 2>/dev/null; then
      COMMITS_BEHIND=$((COMMITS_BEHIND - 1))
    fi

    # Get commit messages since the built revision (excluding the post-build commit)
    COMMITS=$(git log "$BUILT_REV_CLEAN"..HEAD --pretty=format:"%s" 2>/dev/null | while IFS= read -r line; do
      if echo "$line" | grep -q ":"; then
        MESSAGE=$(echo "$line" | cut -d':' -f2-)
        MESSAGE=$(echo "$MESSAGE" | sed 's/ ([^)]*)$//')
        MESSAGE=$(echo "$MESSAGE" | sed 's/^ *//;s/ *$//')
        echo "• $MESSAGE"
      else
        echo "• $line"
      fi
    done)

    CHANGED_FILES=$(git diff --name-only "$BUILT_REV_CLEAN" HEAD 2>/dev/null | head -10 | sed 's/^/• /')
    FILE_COUNT=$(git diff --name-only "$BUILT_REV_CLEAN" HEAD 2>/dev/null | wc -l)

    if [ "$FILE_COUNT" -gt 10 ]; then
      CHANGED_FILES="$CHANGED_FILES
    • ... and $((FILE_COUNT - 10)) more files"
    fi

    ${
      if hasDesktop
      then ''
        if command -v zenity &> /dev/null; then
          zenity --info \
            --title="NixOS Build Outdated" \
            --text="Your running system is $COMMITS_BEHIND commit(s) behind the config.\n\n<b>Unbuilt changes:</b>\n$COMMITS\n\n<b>Changed files:</b>\n$CHANGED_FILES\n\nRun <b>nix-switch</b> to rebuild." \
            --width=500 \
            --height=400 &
        fi
        notify-send "NixOS Build Outdated" "System is $COMMITS_BEHIND commit(s) behind config. Run nix-switch to rebuild." --icon=dialog-warning
      ''
      else ''
            mkdir -p "${stateDir}"
            cat > "${stateDir}/build-stale" << ENDMSG
        COMMITS_BEHIND=$COMMITS_BEHIND
        COMMITS=$(echo "$COMMITS" | sed 's/"/\\"/g')
        CHANGED_FILES=$(echo "$CHANGED_FILES" | sed 's/"/\\"/g')
        ENDMSG
      ''
    }
  '';

  # Terminal banner script for server (reads state files and displays on login)
  terminalBanner = pkgs.writeShellScriptBin "nix-sync-banner" ''
    #!/usr/bin/env sh

    # Colors
    yellow='\033[0;33m'
    cyan='\033[0;36m'
    green='\033[0;32m'
    bold='\033[1m'
    reset='\033[0m'
    dim='\033[2m'

    SHOWN=false

    # Check remote sync state
    STATE_FILE="${stateDir}/update-available"
    if [ -f "$STATE_FILE" ]; then
      . "$STATE_FILE"
      if [ -n "$BEHIND" ] && [ "$BEHIND" != "0" ]; then
        SHOWN=true
        echo ""
        echo -e "''${yellow}''${bold}  NixOS config is $BEHIND commit(s) behind remote''${reset}"
        echo -e "''${dim}  ──────────────────────────────────────────────''${reset}"
        echo ""
        echo -e "''${cyan}  Commits:''${reset}"
        echo "$COMMITS" | while IFS= read -r line; do
          echo -e "    ''${green}$line''${reset}"
        done
        echo ""
        echo -e "''${cyan}  Changed files:''${reset}"
        echo "$CHANGED_FILES" | while IFS= read -r line; do
          echo -e "    $line"
        done
        echo ""
        echo -e "''${dim}  Run 'nix-pull' to pull changes or 'nix-check-remote' to re-check''${reset}"
        echo ""
      else
        rm -f "$STATE_FILE"
      fi
    fi

    # Check build freshness state
    BUILD_FILE="${stateDir}/build-stale"
    if [ -f "$BUILD_FILE" ]; then
      # Reset variables to avoid leaking from the previous source
      COMMITS=""
      CHANGED_FILES=""
      . "$BUILD_FILE"
      if [ -n "$COMMITS_BEHIND" ] && [ "$COMMITS_BEHIND" != "0" ]; then
        SHOWN=true
        echo ""
        echo -e "''${yellow}''${bold}  NixOS build is $COMMITS_BEHIND commit(s) behind config''${reset}"
        echo -e "''${dim}  ──────────────────────────────────────────────''${reset}"
        echo ""
        echo -e "''${cyan}  Unbuilt changes:''${reset}"
        echo "$COMMITS" | while IFS= read -r line; do
          echo -e "    ''${green}$line''${reset}"
        done
        echo ""
        echo -e "''${cyan}  Changed files:''${reset}"
        echo "$CHANGED_FILES" | while IFS= read -r line; do
          echo -e "    $line"
        done
        echo ""
        echo -e "''${dim}  Run 'nix-switch' to rebuild''${reset}"
        echo ""
      else
        rm -f "$BUILD_FILE"
      fi
    fi
  '';
in {
  config = lib.mkMerge [
    # Shared: check scripts are always available
    {
      home.packages = [checkScript buildCheckScript];
    }

    # Desktop: GUI notifications via zenity + notify-send
    (lib.mkIf hasDesktop {
      home.packages = [pkgs.zenity];

      systemd.user.services.nix-config-sync-check = {
        Unit = {
          Description = "Check for NixOS config updates from remote";
          After = ["graphical-session.target" "network-online.target"];
        };

        Service = {
          Type = "oneshot";
          ExecStart = "${pkgs.writeShellScript "nix-sync-check" ''
            sleep 15
            ${checkScript}/bin/nix-check-remote
          ''}";
          RemainAfterExit = false;
        };

        Install = {
          WantedBy = ["graphical-session.target"];
        };
      };

      systemd.user.services.nix-build-freshness-check = {
        Unit = {
          Description = "Check if NixOS build matches latest config";
          After = ["graphical-session.target"];
        };

        Service = {
          Type = "oneshot";
          ExecStart = "${pkgs.writeShellScript "nix-build-check" ''
            sleep 20
            ${buildCheckScript}/bin/nix-check-build
          ''}";
          RemainAfterExit = false;
        };

        Install = {
          WantedBy = ["graphical-session.target"];
        };
      };
    })

    # Server: terminal banner on login + periodic timers
    (lib.mkIf (!hasDesktop) {
      home.packages = [terminalBanner];

      systemd.user.services.nix-config-sync-check = {
        Unit = {
          Description = "Check for NixOS config updates from remote";
          After = ["network-online.target"];
        };

        Service = {
          Type = "oneshot";
          ExecStart = "${checkScript}/bin/nix-check-remote";
          RemainAfterExit = false;
        };
      };

      systemd.user.services.nix-build-freshness-check = {
        Unit = {
          Description = "Check if NixOS build matches latest config";
        };

        Service = {
          Type = "oneshot";
          ExecStart = "${buildCheckScript}/bin/nix-check-build";
          RemainAfterExit = false;
        };
      };

      systemd.user.timers.nix-config-sync-check = {
        Unit = {
          Description = "Periodically check for NixOS config updates";
        };

        Timer = {
          OnBootSec = "2min";
          OnUnitActiveSec = "1h";
          Persistent = true;
        };

        Install = {
          WantedBy = ["timers.target"];
        };
      };

      systemd.user.timers.nix-build-freshness-check = {
        Unit = {
          Description = "Periodically check if NixOS build is current";
        };

        Timer = {
          OnBootSec = "2min";
          OnUnitActiveSec = "1h";
          Persistent = true;
        };

        Install = {
          WantedBy = ["timers.target"];
        };
      };

      # Show banner on shell login
      programs.zsh.initContent = ''
        # Show NixOS config sync and build freshness notifications
        ${terminalBanner}/bin/nix-sync-banner
      '';
    })
  ];
}
